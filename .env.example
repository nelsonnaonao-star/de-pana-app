# =============================================================
# RED ON — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=           # anon/public key (client-side)
SUPABASE_SERVICE_KEY=             # service_role key (server-side, NEVER expose to client)
SUPABASE_JWT_SECRET=              # JWT secret from Supabase dashboard > API > JWT Secret

# ── Firebase / Push Notifications ────────────────────────────
# Client-side (bundled into JS):
VITE_FIREBASE_VAPID_KEY=          # Web Push VAPID public key

# Server-side (NEVER expose to client):
FIREBASE_SERVICE_ACCOUNT_JSON=    # Full Firebase service account JSON (paste as string)
FIREBASE_PRIVATE_VAPID_KEY=       # Web Push VAPID private key

# ── Server ───────────────────────────────────────────────────
PORT=5000
APP_URL=http://localhost:3000
VITE_SERVER_URL=http://localhost:5000

# ── Gemini AI (optional) ─────────────────────────────────────
GEMINI_API_KEY=

# ── GIPHY (optional) ─────────────────────────────────────────
GIPHY_API_KEY=

# ── Twilio SMS (optional, for password reset) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── WebRTC TURN (for video/audio calls) ──────────────────────
METERED_API_KEY=
METERED_SUBDOMAIN=onchat

# ── FCM Webhook ──────────────────────────────────────────────
FCM_WEBHOOK_SECRET=               # Shared secret for Supabase DB webhook → FCM endpoint
